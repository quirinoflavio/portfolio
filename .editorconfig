root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{js,jsx,ts,tsx}]
charset = utf-8
max_line_length = 120

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
indent_style = space
trim_trailing_whitespace = false
insert_final_newline = true
max_line_length = 80

[*.html]
max_line_length = 120
